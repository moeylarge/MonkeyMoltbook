generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  RESTRICTED
  BANNED
}

enum ThreadStatus {
  OPEN
  CLOSED
  ARCHIVED
  SPAM_REVIEW
}

enum DeliveryChannel {
  INBOX
  EMAIL
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  SUPPRESSED
}

enum CreditLedgerReason {
  MESSAGE_SEND
  MESSAGE_REPLY
  ADMIN_GRANT
  ADMIN_DEBIT
  REFUND
}

enum AuditAction {
  AUTH_STARTED
  AUTH_VERIFIED
  AUTH_FAILED
  LOGOUT
  MAILBOX_OPENED
  THREAD_OPENED
  THREAD_CREATED
  MESSAGE_SENT
  MESSAGE_REPLY_SENT
  MESSAGE_DELIVERY_QUEUED
  MESSAGE_DELIVERY_FAILED
  CREDIT_DEBITED
  CREDIT_REFUNDED
  RATE_LIMIT_HIT
  USER_RESTRICTED
  USER_BANNED
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  emailVerifiedAt    DateTime?
  displayName        String?
  handle             String?           @unique
  avatarUrl          String?
  status             UserStatus        @default(ACTIVE)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lastLoginAt        DateTime?
  authAccounts       AuthAccount[]
  sessions           Session[]
  wallet             CreditWallet?
  creditLedger       CreditLedger[]
  sentMessages       MailMessage[]     @relation("SentMessages")
  threadCreated      MailThread[]      @relation("ThreadCreatedBy")
  threadParticipants MailParticipant[]
  auditLogs          AuditLog[]
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  ipHash     String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id           String             @id @default(cuid())
  userId       String
  delta        Int
  reason       CreditLedgerReason
  messageId    String?
  createdAt    DateTime           @default(now())
  metadataJson Json?
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      MailMessage?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([messageId])
}

model MailThread {
  id              String            @id @default(cuid())
  subject         String
  createdByUserId String
  status          ThreadStatus      @default(OPEN)
  lastMessageAt   DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       User              @relation("ThreadCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  participants    MailParticipant[]
  messages        MailMessage[]

  @@index([createdByUserId])
  @@index([lastMessageAt])
  @@index([status])
}

model MailParticipant {
  id         String     @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime?
  archivedAt DateTime?
  createdAt  DateTime   @default(now())
  thread     MailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
  @@index([threadId])
}

model MailMessage {
  id           String         @id @default(cuid())
  threadId     String
  senderUserId String
  bodyText     String
  createdAt    DateTime       @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?
  thread       MailThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       User           @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  deliveries   MailDelivery[]
  creditLedger CreditLedger[]

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
}

model MailDelivery {
  id                String         @id @default(cuid())
  messageId         String
  recipientUserId   String
  channel           DeliveryChannel
  status            DeliveryStatus @default(QUEUED)
  providerMessageId String?
  attemptCount      Int            @default(0)
  lastAttemptAt     DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  message           MailMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([recipientUserId, status])
  @@index([status, createdAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  actorUserId  String?
  action       AuditAction
  entityType   String
  entityId     String?
  ipHash       String?
  userAgent    String?
  metadataJson Json?
  createdAt    DateTime    @default(now())
  actor        User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}
