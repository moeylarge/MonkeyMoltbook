{
  "framework": null,
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/collect-rolling", "schedule": "*/10 * * * *" },
    { "path": "/api/refresh-fast", "schedule": "*/15 * * * *" },
    { "path": "/api/refresh-full", "schedule": "*/30 * * * *" },
    { "path": "/api/reindex-search", "schedule": "0 * * * *" }
  ],
  "rewrites": [
    { "source": "/api/refresh", "destination": "/api/refresh.mjs" },
    { "source": "/api/refresh-fast", "destination": "/api/refresh-fast.mjs" },
    { "source": "/api/refresh-full", "destination": "/api/refresh-full.mjs" },
    { "source": "/api/collect-rolling", "destination": "/api/collect-rolling.mjs" },
    { "source": "/api/reindex-search", "destination": "/api/reindex-search.mjs" },
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
